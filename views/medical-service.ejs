<%- include('partials/head.ejs') %>

    <body>
        <%- include('partials/sidebar.ejs') %>
            <%- include('partials/header.ejs') %>
                <main class="nxl-container">
                    <div class="nxl-content">
                        <div class="page-header">
                            <div class="page-header-left d-flex align-items-center">
                                <div class="page-header-title">
                                    <h5 class="m-b-10">B-Leave</h5>
                                </div>
                                <ul class="breadcrumb">
                                    <li class="breadcrumb-item">Medical service</li>
                                    <li class="breadcrumb-item">List</li>
                                </ul>
                            </div>
                        </div>

                        <div class="main-content">
                            <div class="tab-content">
                                <div class="tab-pane fade active show" id="overviewTab">
                                    <div class="row">
                                        <div class="col-12">
                                            <div class="card stretch stretch-full">
                                                <div class="card-header">
                                                    <h5 class="card-title">Medical Service list</h5>

                                                    <!-- Filtres -->
                                                    <form method="GET" action="/smia-ostie/list"
                                                        class="d-flex align-items-end gap-3 mt-2 flex-wrap">
                                                        <div>
                                                            <label class="form-label mb-1">Recherche</label>
                                                            <input type="text" name="search" class="form-control"
                                                                placeholder="Matricule, nom..." value="<%= search %>" />
                                                        </div>
                                                        <div>
                                                            <label class="form-label mb-1">Date début</label>
                                                            <input type="date" name="startDate" class="form-control"
                                                                value="<%= startDate %>" />
                                                        </div>
                                                        <div>
                                                            <label class="form-label mb-1">Date fin</label>
                                                            <input type="date" name="endDate" class="form-control"
                                                                value="<%= endDate %>" />
                                                        </div>
                                                        <div class="d-flex gap-2">
                                                            <button type="submit" class="btn btn-primary">
                                                                <i class="feather-search me-1"></i> Filtrer
                                                            </button>
                                                            <a href="/smia-ostie/list"
                                                                class="btn btn-outline-secondary ms-2">
                                                                <i class="feather-x me-1"></i> Reset
                                                            </a>
                                                        </div>
                                                    </form>
                                                </div>

                                                <div class="card-body custom-card-action p-0">
                                                    <div class="table-responsive mb-3">
                                                        <table class="table table-hover mb-0">
                                                            <thead>
                                                                <tr>
                                                                    <th>Matricule</th>
                                                                    <th>Fullname</th>
                                                                    <th>Date</th>
                                                                    <th>Reason</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <% data.forEach(d=> { %>
                                                                    <tr>
                                                                        <td>
                                                                            <%= d.employee.matricule %>
                                                                        </td>
                                                                        <td>
                                                                            <%= d.employee.fullname %>
                                                                        </td>
                                                                        <td>
                                                                            <%= d.date %>
                                                                        </td>
                                                                        <td>
                                                                            <%= d.reason %>
                                                                        </td>
                                                                    </tr>
                                                                    <% }) %>
                                                                        <% if (data.length===0) { %>
                                                                            <tr>
                                                                                <td colspan="4"
                                                                                    class="text-center text-muted py-4">
                                                                                    Aucun résultat trouvé.</td>
                                                                            </tr>
                                                                            <% } %>
                                                            </tbody>
                                                        </table>
                                                    </div>

                                                    <!-- Pagination -->
                                                    <div
                                                        class="d-flex align-items-center justify-content-between px-3 pb-3">
                                                        <small class="text-muted">
                                                            Total : <strong>
                                                                <%= total %>
                                                            </strong> enregistrement(s)
                                                        </small>
                                                        <% if (totalPages> 1) { %>
                                                            <ul class="pagination mb-0">

                                                                <!-- Précédent -->
                                                                <li
                                                                    class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                                                    <a class="page-link"
                                                                        href="?page=<%= currentPage - 1 %>&search=<%= search %>&startDate=<%= startDate %>&endDate=<%= endDate %>">
                                                                        <i class="feather-chevron-left"></i>
                                                                    </a>
                                                                </li>

                                                                <!-- Première page si hors plage -->
                                                                <% if (startPage> 1) { %>
                                                                    <li class="page-item">
                                                                        <a class="page-link"
                                                                            href="?page=1&search=<%= search %>&startDate=<%= startDate %>&endDate=<%= endDate %>">1</a>
                                                                    </li>
                                                                    <% if (startPage> 2) { %>
                                                                        <li class="page-item disabled"><span
                                                                                class="page-link">…</span></li>
                                                                        <% } %>
                                                                            <% } %>

                                                                                <!-- Pages numérotées -->
                                                                                <% for (let i=startPage; i <=endPage;
                                                                                    i++) { %>
                                                                                    <li
                                                                                        class="page-item <%= i === currentPage ? 'active' : '' %>">
                                                                                        <a class="page-link"
                                                                                            href="?page=<%= i %>&search=<%= search %>&startDate=<%= startDate %>&endDate=<%= endDate %>">
                                                                                            <%= i %>
                                                                                        </a>
                                                                                    </li>
                                                                                    <% } %>

                                                                                        <!-- Dernière page si hors plage -->
                                                                                        <% if (endPage < totalPages) {
                                                                                            %>
                                                                                            <% if (endPage < totalPages
                                                                                                - 1) { %>
                                                                                                <li
                                                                                                    class="page-item disabled">
                                                                                                    <span
                                                                                                        class="page-link">…</span>
                                                                                                </li>
                                                                                                <% } %>
                                                                                                    <li
                                                                                                        class="page-item">
                                                                                                        <a class="page-link"
                                                                                                            href="?page=<%= totalPages %>&search=<%= search %>&startDate=<%= startDate %>&endDate=<%= endDate %>">
                                                                                                            <%= totalPages
                                                                                                                %>
                                                                                                        </a>
                                                                                                    </li>
                                                                                                    <% } %>

                                                                                                        <!-- Suivant -->
                                                                                                        <li
                                                                                                            class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                                                                                            <a class="page-link"
                                                                                                                href="?page=<%= currentPage + 1 %>&search=<%= search %>&startDate=<%= startDate %>&endDate=<%= endDate %>">
                                                                                                                <i
                                                                                                                    class="feather-chevron-right"></i>
                                                                                                            </a>
                                                                                                        </li>

                                                            </ul>
                                                            <% } %>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <%- include('partials/footer.ejs') %>
                </main>
    </body>