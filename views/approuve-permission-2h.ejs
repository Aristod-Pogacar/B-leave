<%- include('partials/head.ejs') %>

    <body>
        <%- include('partials/sidebar.ejs') %>
            <%- include('partials/header.ejs') %>
                <main class="nxl-container">
                    <div class="nxl-content">
                        <div class="page-header">
                            <div class="page-header-left d-flex align-items-center">
                                <div class="page-header-title">
                                    <h5 class="m-b-10">B-Leave</h5>
                                </div>
                                <ul class="breadcrumb">
                                    <li class="breadcrumb-item">Permission 2h</li>
                                    <li class="breadcrumb-item">Approve permission 2h</li>
                                </ul>
                            </div>
                            <div class="page-header-right ms-auto">
                                <div class="page-header-right-items">
                                    <div class="d-flex d-md-none">
                                        <a href="javascript:void(0)" class="page-header-right-close-toggle">
                                            <i class="feather-arrow-left me-2"></i>
                                            <span>Back</span>
                                        </a>
                                    </div>
                                </div>
                                <div class="d-md-none d-flex align-items-center">
                                    <a href="javascript:void(0)" class="page-header-right-open-toggle">
                                        <i class="feather-align-right fs-20"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                        <!-- [ page-header ] end -->
                        <div class="bg-white py-3 border-bottom rounded-0 p-md-0 mb-0">
                            <div class="d-md-none d-flex align-items-center justify-content-between">
                                <a href="javascript:void(0)" class="page-content-left-open-toggle">
                                    <i class="feather-align-left fs-20"></i>
                                </a>
                            </div>
                        </div>
                        <!-- [ Main Content ] start -->
                        <div class="main-content">
                            <div class="tab-content">
                                <div class="tab-pane fade active show" id="overviewTab">
                                    <div class="row">

                                        <div class="col-12">
                                            <div class="card stretch stretch-full">
                                                <div class="card-header">
                                                    <h5 class="card-title">Approve leaves</h5>
                                                    <div
                                                        class="col-10 task-header d-md-flex align-items-center justify-content-between">
                                                        <div class="me-4 w-75">
                                                        </div>
                                                        <div class="">
                                                            <div class="d-flex gap-2">
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="card-body custom-card-action p-0">
                                                    <div class="table-responsive mb-3">
                                                        <table class="table table-hover mb-0">
                                                            <thead>
                                                                <tr>
                                                                    <th style="width: 10%;">Matricule</th>
                                                                    <th style="width: 30%;">Fullname</th>
                                                                    <th style="width: 10%;">Date</th>
                                                                    <th style="width: 10%;">Start time</th>
                                                                    <th style="width: 10%;">End time</th>
                                                                    <th class="text-center">Action</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <% permissions.forEach(d=> { %>
                                                                    <tr>
                                                                        <td style="width: 10%;">
                                                                            <%= d.employee.matricule %>
                                                                        </td>
                                                                        <td style="width: 30%;">
                                                                            <%= d.employee.fullname %>
                                                                        </td>
                                                                        <td style="width: 10%;">
                                                                            <%= d.date %>
                                                                        </td>
                                                                        <td style="width: 10%;">
                                                                            <%= d.expectedStartTime %>
                                                                        </td>
                                                                        <td style="width: 10%;">
                                                                            <%= d.expectedEndTime %>
                                                                        </td>
                                                                        <td class="justify-content-center d-flex gap-2">
                                                                            <form
                                                                                action="/permission2h/approve-permission-2h/<%= d.id %>"
                                                                                method="post">
                                                                                <button type="submit"
                                                                                    class="btn btn-success"
                                                                                    title="Approve"><i
                                                                                        class="feather-check"></i></button>
                                                                            </form>
                                                                            <form
                                                                                action="/permission2h/reject-permission-2h/<%= d.id %>"
                                                                                method="post">
                                                                                <button type="submit"
                                                                                    class="btn btn-danger"
                                                                                    title="Reject"><i
                                                                                        class="feather-x"></i></button>
                                                                            </form>
                                                                        </td>
                                                                    </tr>
                                                                    <% }) %>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <%- include('partials/footer.ejs') %>